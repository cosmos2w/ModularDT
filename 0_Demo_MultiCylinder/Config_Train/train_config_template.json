    "best_metric_name": "val_residual_focus",
    "residual_focus_field_weight": 0.25,
    "early_stopping_patience": 500,
    "eval_every_epochs": 1,
    "max_cases": 18,
    "batch_size": 144,
    "num_workers": 4,
    "points_per_item": 4096,
    "point_fraction": 0.15,
    "min_points_per_sample": 1024,
    "resample_each_eval": false,
    "seed": 42,
    "query_batch_size": 32768,
