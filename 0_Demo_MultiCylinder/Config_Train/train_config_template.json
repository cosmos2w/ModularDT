    "dynamic_energy_log_space": true,
    "dynamic_energy_eps": 1.0e-8,
    "dynamic_energy_use_smooth_l1": true,

    "organizer_sparsity_weight": 0.0,
    "organizer_entropy_weight": 0.0,
