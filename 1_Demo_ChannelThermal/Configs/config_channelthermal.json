{
  "description": "Global channel thermal test config. Generates raw global frames for preprocessing into Processed_ChannelThermal_Dataset/packed_dataset.h5.",
  "data_contract": {
    "global_channels": [
      "u",
      "v",
      "p",
      "omega",
      "temperature"
    ],
    "preferred_interface_inputs": "preprocessed interface_condition",
    "preferred_interface_targets": "preprocessed interface_target"
  },
  "domain": {
    "nx": 128,
    "ny": 64,
    "lx": 12.0,
    "ly": 4.0,
    "module_radius": 0.45,
    "min_gap": 0.20,
    "inlet_margin": 1.0,
    "outlet_margin": 1.0,
    "wall_margin": 0.55
  },
  "flow": {
    "re": 50.0,
    "u_in": 1.0,
    "dt": 0.01,
    "warmup_time": 10.0,
    "solve_time": 50.0,
    "save_stride": 50,
    "viscosity_scale": 1.0,
    "nu": null,
    "pressure_rank_deficiency": 0,
    "flow_model": "analytic_wake",
    "apply_projection": false,
    "projection_iterations": 200,
    "projection_relaxation": 1.5
  },
  "thermal": {
    "enabled": true,
    "t_in": 0.0,
    "t_wall": 0.0,
    "solid_alpha": 0.01,
    "fluid_alpha": 0.02,
    "solid_k": 1.0,
    "fluid_k": 1.0,
    "heat_power_min": 0.5,
    "heat_power_max": 2.0,
    "heat_start_time": 0.10,
    "stop_on_convergence": true,
    "min_solve_time": 10.0,
    "max_solve_time": 200.0,
    "max_steps": null,
    "convergence_window": 10,
    "convergence_tol": 1e-4,
    "convergence_rel_tol": 1e-5,
    "require_heat_active_for_convergence": true
  },
  "layout": {
    "num_modules": 2,
    "seed": 1,
    "centers": null,
    "heat_powers": null
  },
  "save": {
    "root_dir": "./Data_Saved",
    "case_id": "0001",
    "tag": "channelthermal",
    "save_pressure": true,
    "save_vorticity": true,
    "save_temperature": true,
    "save_internal_temperature": true,
    "save_interface_response": true,
    "final_window_frames": 5
  },
  "local_module": {
    "local_grid_size": 64,
    "n_interface_points": 64,
    "q_min": 0.5,
    "q_max": 2.0,
    "h_min": 0.2,
    "h_max": 3.0,
    "t_env_min": -0.5,
    "t_env_max": 0.5,
    "n_boundary_modes": 4,
    "solver_iterations": 3000,
    "solver_tolerance": 1e-6,
    "relaxation": 1.25
  },
  "execution": {
    "device": "cpu",
    "gpu_id": 0
  }
}
