    "local_surrogate_interface_target_weights": [1.0, 0.25],
    "interface_loss_type": "smooth_l1",
    "port_condition_weight": 0.3,
    "port_temperature_weight": 1.0,
    "port_h_weight": 1.0,
    "port_temperature_scale": 10.0,
    "_note_port_h_scale": "Deprecated: h_effective is trained in log1p space with interface_condition_valid_mask, so port_h_scale is ignored.",
    "_note_organizer_strength_weight": "Organizer strength is logged as diag_organizer_strength_mean only. Positive organizer_strength_weight used to penalize strong hyperedges and should usually stay 0.0.",
    "organizer_strength_weight": 0.0,
    "_note_organizer_direct": "Weak channel organizer losses: prior-guided A_me, direct A_eh factor target, and module/environment mass alignment. Entropy/sparsity losses are intentionally off by default.",
    "organizer_me_weight": 0.01,
    "organizer_eh_factor_weight": 0.05,
    "organizer_mass_align_weight": 0.02,
    "organizer_mm_weight": 0.0,
    "organizer_eh_factor_target_source": "prior_me",
    "organizer_eh_factor_detach_mh": true,
    "organizer_mass_align_log_space": true,
    "organizer_mass_align_detach_module": true,
    "organizer_eps": 0.000001,
    "organizer_me_sigma_distance": 1.5,
    "organizer_me_sigma_downstream": 2.0,
    "organizer_me_sigma_lateral": 0.9,
    "organizer_me_wall_weight": 0.15,
    "organizer_me_heat_power_weight": 0.15,
    "field_channel_weights": null
  },
  "training": {
    "epochs": 10000,
    "learning_rate": 0.0001,
    "weight_decay": 0.00001,
    "gradient_clip_norm": 1.0,
    "amp": false,
    "seed": 42,
    "device": null,
    "local_port_condition_mode": "teacher",
    "port_condition_schedule": "teacher_to_predicted",
    "teacher_epochs": 50,
    "mixed_epochs": 150,
    "predicted_after_epoch": 200,
    "mixed_teacher_ratio": 0.5,
    "mixed_teacher_ratio_start": 1.0,
    "mixed_teacher_ratio_end": 0.0,
    "organizer_schedule": "warmup_decay",
    "organizer_full_until_epoch": 100,
    "organizer_decay_end_epoch": 300,
    "organizer_decay_factor_final": 0.2,
    "max_train_batches_per_epoch": null,
    "max_val_batches": null
  },
  "checkpointing": {
    "save_best": true,
    "save_latest": true
  },
  "paths": {
    "saved_model_dir": "./Saved_Model"
  },
  "stage_c_future": {
    "_note": "For later joint fine-tuning, set freeze_local_surrogate=false after Stage B is stable and lower the learning rate."
  }
