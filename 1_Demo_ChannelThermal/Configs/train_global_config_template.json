{
  "Run_ID": "0002",
  "_note_1": "Default is a global-only baseline. Set model.use_local_surrogate=true and provide a local checkpoint after Stage A is trained.",
  "_note_2": "0002 tests using new local module surrogate & updated hypergraph learning",
  "dataset": {
    "packed_h5_path": "./Data_Saved/Processed_ChannelThermal_Dataset/packed_dataset.h5",
    "train_split": "train",
    "val_split": "test",
    "points_per_case": 4096,
    "val_points_per_case": 4096,
    "batch_size": 32,
    "val_batch_size": 32,
    "num_workers": 4,
    "random_point_sampling": true,
    "normalize_inputs": true,
    "normalize_targets": true,
    "require_converged": true
  },
  "model": {
    "field_dim": 5,
    "field_names": ["u", "v", "p", "omega", "temperature"],
    "max_num_modules": "auto",
    "domain_length_x": "auto",
    "domain_length_y": "auto",
    "module_radius": "auto",
    "num_env_tokens_x": 16,
    "num_env_tokens_y": 8,
    "num_hyperedges": 6,
    "hidden_dim": 96,
    "latent_dim": 96,

    "use_local_surrogate": true,
    "local_surrogate_checkpoint_path": "./Saved_Model_LocalModule/Run_0002_20260507_085853/latest_model.pt",
    "freeze_local_surrogate": true,
    "local_surrogate_latent_dim": 128,
    "local_surrogate_flux_mode": "corrected_physics",
    "local_surrogate_flux_blend_alpha": 0.5,
    "future_global_feature_dim": 0,
    "dropout": 0.0,
    "use_layer_norm": true,
    "DISABLE_EDGE": false,
    "disable_edge_strength_threshold": 0.05,
    "use_hyper_specific_eh_geometry": true,
    "thermal_prior_sigma_distance": 1.5,
    "thermal_prior_sigma_downstream": 2.0,
    "thermal_prior_sigma_lateral": 0.9,
    "thermal_prior_wall_weight": 0.15,
    "thermal_prior_heat_power_weight": 0.15
  },
  "loss": {
    "field_mse_weight": 1.0,
    "temperature_weight": 1.0,
    "internal_temperature_weight": 1.0,
    "interface_weight": 0.2,
    "interface_target_weights": null,
